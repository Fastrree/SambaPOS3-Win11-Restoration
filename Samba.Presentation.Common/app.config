    <userSettings>
        <Samba.Presentation.Common.Properties.Settings>
            <setting name="DashboardHeight" serializeAs="String">
                <value>600</value>
            </setting>
            <setting name="DashboardWidth" serializeAs="String">
                <value>800</value>
            </setting>
            <setting name="VCHeight" serializeAs="String">
